# This file is now OPTIONAL on devnet: every value below has a working
# default baked into src/config.ts (the deployed USDC mint, the committed
# IDL, and an admin key that is auto-generated to data/admin-key.txt on
# first boot). Copy to .env only to override something.
NETWORK=devnet
PORT=8787
KEYPAIR_PATH=./keypair.json        # the CI deploy wallet (ask Claude / see DEVNET.md)
#ADMIN_KEY=pick-something-secret   # unset = auto-generated, printed + saved to data/admin-key.txt
TXLINE_SERVICE_LEVEL=1             # free World Cup tier
USDC_MINT=FWJiwiotctjZcgqe37sfRRfZh2hqEKZ31syc3GFS4PbU  # created by CI deploy (DEVNET.md)
TXORACLE_IDL=../idls/txoracle.json # download from TxLINE docs: programs/devnet
VAULT_IDL=./target-idl/prop_vault.json  # committed copy generated at the deployed program id
# Demo mode: point at a recording and everything replays through the same pipeline
# REPLAY_FILE=data/recordings/scores-2026-07-10.jsonl
# REPLAY_SPEED=20
